rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Test connection path
    match /test/connection {
      allow read: if true;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'class', 'language', 'teacherChoice', 'createdAt', 'timeStudiedMins', 'chaptersCompleted', 'streak', 'points', 'lastActivityAt'])
        && data.keys().size() == 11
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 200
        && data.class is string && data.class.size() > 0 && data.class.size() <= 50
        && data.language is string && data.language.size() > 0 && data.language.size() <= 50
        && data.teacherChoice is string && data.teacherChoice.size() > 0 && data.teacherChoice.size() <= 50
        && data.createdAt is timestamp
        && data.timeStudiedMins is number && data.timeStudiedMins >= 0
        && data.chaptersCompleted is number && data.chaptersCompleted >= 0
        && data.streak is number && data.streak >= 0
        && data.points is number && data.points >= 0
        && (data.lastActivityAt == null || data.lastActivityAt is timestamp)
        && data.email == request.auth.token.email;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
                    && isValidId(userId)
                    && isValidUser(incoming())
                    && incoming().createdAt == request.time
                    && incoming().timeStudiedMins == 0
                    && incoming().chaptersCompleted == 0
                    && incoming().streak == 0
                    && incoming().points == 0;
      allow update: if isOwner(userId)
                    && isValidId(userId)
                    && incoming().diff(existing()).affectedKeys().hasOnly(['timeStudiedMins', 'chaptersCompleted', 'streak', 'points', 'class', 'language', 'teacherChoice', 'name', 'lastActivityAt'])
                    && incoming().createdAt == existing().createdAt
                    && incoming().email == existing().email
                    && incoming().name is string && incoming().name.size() <= 100
                    && incoming().teacherChoice is string && incoming().teacherChoice.size() <= 50
                    && incoming().language is string && incoming().language.size() <= 50
                    && incoming().class is string && incoming().class.size() <= 50
                    && incoming().timeStudiedMins is number && incoming().timeStudiedMins >= 0
                    && incoming().chaptersCompleted is number && incoming().chaptersCompleted >= 0
                    && incoming().streak is number && incoming().streak >= 0
                    && incoming().points is number && incoming().points >= 0;
      
      match /chats/{chatId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId)
                      && isValidId(chatId)
                      && incoming().keys().hasAll(['userId', 'role', 'text', 'createdAt'])
                      && incoming().keys().size() == 4
                      && incoming().userId == userId
                      && incoming().role in ['user', 'model']
                      && incoming().text is string && incoming().text.size() <= 10000
                      && incoming().createdAt == request.time;
      }
      
      match /tasks/{taskId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId)
                      && isValidId(taskId)
                      && incoming().keys().hasAll(['userId', 'title', 'subject', 'duration', 'status', 'color', 'createdAt'])
                      && incoming().keys().size() == 7
                      && incoming().userId == userId
                      && incoming().title is string && incoming().title.size() <= 200
                      && incoming().subject is string && incoming().subject.size() <= 100
                      && incoming().duration is string && incoming().duration.size() <= 50
                      && incoming().status in ['pending', 'completed']
                      && incoming().color is string && incoming().color.size() <= 100
                      && incoming().createdAt == request.time;
        allow update: if isOwner(userId)
                      && isValidId(taskId)
                      && (
                        (incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status in ['pending', 'completed']) ||
                        isOwner(userId) // General update for owner but limited by user update block usually. 
                        // Actually task update for other fields can be restricted here too if needed. 
                      );
        allow delete: if isOwner(userId) && isValidId(taskId);
      }

      match /notes/{noteId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId)
                      && isValidId(noteId)
                      && incoming().keys().hasAll(['userId', 'title', 'content', 'createdAt', 'updatedAt'])
                      && incoming().keys().size() == 5
                      && incoming().userId == userId
                      && incoming().title is string && incoming().title.size() <= 200
                      && incoming().content is string && incoming().content.size() <= 50000
                      && incoming().createdAt == request.time
                      && incoming().updatedAt == request.time;
        allow update: if isOwner(userId)
                      && isValidId(noteId)
                      && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'updatedAt'])
                      && (incoming().title is string && incoming().title.size() <= 200)
                      && (incoming().content is string && incoming().content.size() <= 50000)
                      && incoming().updatedAt == request.time;
        allow delete: if isOwner(userId) && isValidId(noteId);
      }

      match /testResults/{resultId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId)
                      && isValidId(resultId)
                      && incoming().keys().hasAll(['userId', 'templateId', 'title', 'subject', 'score', 'totalQuestions', 'correctAnswers', 'submittedAt', 'resultAvailableAt'])
                      && incoming().keys().size() == 9
                      && incoming().userId == userId
                      && incoming().score is number
                      && incoming().submittedAt == request.time;
      }
      
      match /studySessions/{sessionId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId)
                      && isValidId(sessionId)
                      && incoming().keys().hasAll(['userId', 'subjectId', 'durationSeconds', 'createdAt'])
                      && incoming().keys().size() == 4
                      && incoming().userId == userId
                      && incoming().durationSeconds is number
                      && incoming().createdAt == request.time;
      }
    }
  }
}
